{
  "expo": {
    "name": "Mahmood Rice",
    "slug": "MahmoodRiceApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A148C"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Mahmood Rice to access your camera for scanning QR codes and verifying products."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mahmood Rice to access your photos for product verification."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Mahmood Rice to access your camera for scanning QR codes and verifying products.",
        "NSPhotoLibraryUsageDescription": "Allow Mahmood Rice to access your photos for product verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A148C"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.techywizard.MahmoodRiceApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "83e76048-60a3-42c8-8ed4-25fead1684b7"
      }
    }
  }
}
